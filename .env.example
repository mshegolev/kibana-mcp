# Required — Kibana base URL (no trailing slash)
KIBANA_URL=https://kibana.example.com

# Optional — direct Elasticsearch URL. If not set, ES requests route through
# the Kibana Console proxy (slower but no extra firewall rules needed).
ELASTICSEARCH_URL=https://elasticsearch.example.com:9200

# Authentication — pick ONE of the options below.

# Option 1: Elasticsearch API key (recommended — create in Kibana → Stack Management → API Keys)
KIBANA_API_KEY=

# Option 2: Username + password (HTTP Basic auth)
KIBANA_USERNAME=
KIBANA_PASSWORD=

# SSL verification — set to 'false' for self-signed certificates
KIBANA_SSL_VERIFY=true
